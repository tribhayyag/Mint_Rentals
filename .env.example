# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit it.
# Load into your shell with: `source .env` (run from the repo root).

# Google Maps Platform API key (server-side calls).
# Used by google_maps_commute.py for Directions API and origin lat/lng extraction.
# In Google Cloud Console, enable: Maps JavaScript API (for the frontend map),
# Directions API, and Geocoding API on this project.
# Restrict the key by HTTP referrer (for frontend use) and/or server IP.
export GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# FBI Crime Data Explorer API key.
# Sign up at https://api.data.gov/signup/ — the same key works across api.data.gov.
# Used by crime_safety_rating.py to fetch agency-level offense counts.
export FBI_API_KEY=your-fbi-cde-api-key-here
